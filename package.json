{
  "name": "system-monitor-desktop",
  "version": "1.0.0",
  "description": "系统监控桌面应用",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:stack": "npm run dev:check && concurrently -k -n backend,frontend,agent -c blue,green,yellow \"npm run dev:backend\" \"npm run dev:frontend:standalone\" \"npm run dev:agent\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend:standalone": "cd frontend && npm run dev",
    "dev:agent": "cd agent && py -3 agent.py || python agent.py",
    "dev:check": "node scripts/dev-check.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5174 && electron .",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && electron-builder",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "system-monitor",
    "desktop-app"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^7.6.0",
    "electron": "^20.3.10",
    "electron-builder": "^23.6.0",
    "wait-on": "^7.0.1"
  }
}
