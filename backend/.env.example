# 服务配置
NODE_ENV=development
PORT=50001
HOST=0.0.0.0
WS_PORT=8080

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# InfluxDB 配置
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your_influx_token_here
INFLUX_ORG=eoms
INFLUX_BUCKET=system_monitoring

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=24h
AGENT_API_TOKEN=change_me_agent_token
ALLOW_DEFAULT_ADMIN_PASSWORD=false

# LLM 配置（可选）
# 支持模式：
# 1) ollama（本地）
# 2) 其他大多数云模型：统一走 OpenAI 兼容接口（openai/qwen/deepseek/zhipu/kimi/groq/together/siliconflow 等）

# 当前 provider（例如: openai / qwen / deepseek / zhipu / kimi / groq / together / siliconflow / ollama）
LLM_PROVIDER=openai

# 通用 OpenAI 兼容配置（推荐优先使用）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# provider 专用变量（可选，优先级低于通用变量）
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# QWEN_API_KEY=your_qwen_api_key_here
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# ollama 模式专用（当 LLM_PROVIDER=ollama 时生效）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# 邮件通知配置 (可�?
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL=admin@example.com

# 钉钉通知配置 (可�?
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
DINGTALK_SECRET=YOUR_SECRET


